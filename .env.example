# ===========================================
# TalentScout Hiring Assistant - Configuration
# ===========================================
#
# This file contains configuration for the LLM providers.
# At least one provider must be configured.
#
# Recommended: Use Groq (FREE tier available)
# Get your key at: https://console.groq.com
# ===========================================

# Groq API Key (FREE - Recommended)
# Get your free key at: https://console.groq.com
# Free tier with generous rate limits
GROQ_API_KEY=your-groq-api-key-here

# Groq Model Selection
# Options:
#   - llama-3.3-70b-versatile (best quality, recommended)
#   - llama-3.1-8b-instant (fastest)
#   - mixtral-8x7b-32768 (alternative)
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI API Key (Paid)
# Get your key at: https://platform.openai.com
OPENAI_API_KEY=your-openai-api-key-here

# Ollama Configuration (FREE - Local)
# No API key needed, runs on your machine
# Install: 
#   Windows: winget install Ollama.Ollama
#   macOS: brew install ollama
#   Linux: curl -fsSL https://ollama.com/install.sh | sh
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# LLM Preference
# Options: auto, groq, openai, ollama
# auto = Groq -> OpenAI -> Ollama (priority order)
LLM_PREFERRED=auto

# App Configuration
APP_ENV=development
DEBUG_MODE=false
