# OpenAI API Key (optional - will use Ollama if not set)
OPENAI_API_KEY=your-openai-api-key-here

# Ollama Configuration (optional)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# LLM Preference: auto, openai, ollama
LLM_PREFERRED=auto

# App Configuration
APP_ENV=development
DEBUG_MODE=true
